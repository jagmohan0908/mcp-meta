#
# Required: Meta app credentials
#
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

#
# Optional (recommended for multi-company setup): multiple labeled app credentials in one JSON map.
# Use with request header: X-META-APP-LABEL: <label>
# If set, this takes precedence per label while preserving default fallback.
#
# META_APP_CREDENTIALS_JSON={"default":{"app_id":"123","app_secret":"abc","oauth_redirect_uri":"https://mcp-meta-c9ou.onrender.com/callback"},"dr_health":{"app_id":"456","app_secret":"def","oauth_redirect_uri":"https://mcp-meta-c9ou.onrender.com/callback"}}
META_APP_CREDENTIALS_JSON=

#
# OAuth callback URI (must exactly match your Meta app settings)
# Local development:
# OAUTH_REDIRECT_URI=http://localhost:8888/callback
#
OAUTH_REDIRECT_URI=http://localhost:8888/callback

#
# Required: encryption key for tenant token storage
#
META_MCP_ENCRYPTION_KEY=replace-with-long-random-secret

#
# Optional: SQLite DB path for tenant/token data
#
META_MCP_DB_PATH=/data/meta_ads_mcp.db

#
# Optional quick-start: direct long-lived Meta token
# If set, tools can use this token without OAuth bootstrap.
# For production multi-tenant usage, prefer tenant OAuth flow.
#
META_ACCESS_TOKEN=
